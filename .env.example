# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_SCHEMA_REGISTRY_URL=http://localhost:8081
KAFKA_CONSUMER_GROUP=log-analytics-consumers

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX_PREFIX=logs

# Postgres
POSTGRES_URL=postgresql://loguser:logpass@localhost:5432/logdb

# Redis
REDIS_URL=redis://localhost:6379/0

# API
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# ML
ANOMALY_THRESHOLD=-0.1
FEATURE_WINDOW_SECONDS=60

# Alerts
SLACK_WEBHOOK_URL=